{
  "realm": "sso-demo",
  "enabled": true,
  "displayName": "SSO Demo - PFE",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "eventsEnabled": true,
  "eventsListeners": ["jboss-logging", "kafka"],
  "enabledEventTypes": [
    "LOGIN", "LOGIN_ERROR", "LOGOUT", "LOGOUT_ERROR",
    "REGISTER", "REGISTER_ERROR",
    "REFRESH_TOKEN", "REFRESH_TOKEN_ERROR",
    "CODE_TO_TOKEN", "CODE_TO_TOKEN_ERROR",
    "USER_INFO_REQUEST", "UPDATE_PASSWORD",
    "REMOVE_TOTP", "VERIFY_EMAIL"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "roles": {
    "realm": [
      { "name": "admin",   "description": "Administrateur" },
      { "name": "user",    "description": "Utilisateur standard" },
      { "name": "support", "description": "Support / helpdesk" }
    ]
  },
  "users": [
    {
