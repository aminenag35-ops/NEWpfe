{
  "id": "pfe",
  "realm": "pfe",
  "displayName": "PFE - SSO DevSecOps",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 300,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrateur - accès total"
      },
      {
        "name": "manager",
        "description": "Manager - accès intermédiaire"
      },
      {
        "name": "user",
        "description": "Utilisateur standard"
      }
    ]
  },
  "clients": [
    {
      "clientId": "app-iam",
      "name": "Application IAM",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "iam-secret",
      "redirectUris": [
        "http://10.62.85.1:5001/*"
      ],
      "webOrigins": [
        "http://10.62.85.1:5001"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://10.62.85.1:5001/*"
      },
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "app-ticketing",
      "name": "Application Ticketing",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "ticketing-secret",
