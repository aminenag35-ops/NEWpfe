{
  "id": "pfe",
  "realm": "pfe",
  "displayName": "PFE - SSO DevSecOps",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 300,
  "roles": {
    "realm": [
      { "name": "admin",   "description": "Administrateur" },
      { "name": "manager", "description": "Manager" },
      { "name": "user",    "description": "Utilisateur" }
    ]
  },
  "clients": [
    {
      "clientId": "app-admin",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "admin-secret-pfe",
      "redirectUris": ["http://localhost:5001/*"],
      "webOrigins": ["http://localhost:5001"],
      "attributes": { "post.logout.redirect.uris": "http://localhost:5001/*" },
      "standardFlowEnabled": true,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "app-tickets",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "tickets-secret-pfe",
      "redirectUris": ["http://localhost:5002/*"],
      "webOrigins": ["http://localhost:5002"],
      "attributes": { "post.logout.redirect.uris": "http://localhost:5002/*" },
      "standardFlowEnabled": true,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "app-dashboard",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dashboard-secret-pfe",
      "redirectUris": ["http://localhost:5003/*"],
      "webOrigins": ["http://localhost:5003"],
      "attributes": { "post.logout.redirect.uris": "http://localhost:5003/*" },
      "standardFlowEnabled": true,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@pfe.local",
      "firstName": "Alice", "lastName": "Admin",
      "enabled": true, "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
      "username": "bob",
      "email": "bob@pfe.local",
      "firstName": "Bob", "lastName": "Manager",
      "enabled": true, "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["manager"]
    },
    {
      "username": "charlie",
      "email": "charlie@pfe.local",
      "firstName": "Charlie", "lastName": "User",
      "enabled": true, "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["user"]
    }
  ]
}
